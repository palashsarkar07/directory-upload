{
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./build",
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,

    "lib": ["ES2023", "DOM"],
    "types": ["node"],

    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src"]
}